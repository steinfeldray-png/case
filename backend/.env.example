# Порт сервера
PORT=3000

# Секретный ключ для доступа к админке (любая строка)
ADMIN_KEY=your-secret-key-here

# Публичный URL бэкенда (используется для ссылок на загруженные файлы)
BACKEND_URL=http://localhost:3000

# PostgreSQL (только для server.js, не нужен для server-simple.js)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=your-db-password

# URL фронтенда для CORS
FRONTEND_URL=http://localhost:5173
